$advancement revoke @s only minionskyblock:minion/$(placement_advancement)
scoreboard players set #minion_blocked skyblock_temp 0
execute at @s align xz positioned ~0.5 ~ ~0.5 if entity @e[tag=minion,distance=..0.6] run scoreboard players set #minion_blocked skyblock_temp 1
$execute unless score #minion_blocked skyblock_temp matches 1 if entity @s[y_rotation=-45..45] unless entity @s[y_rotation=45..45] at @s align xz run summon minecraft:armor_stand ~0.5 ~ ~0.5 {Tags:["minion","minion_$(type)","tier_$(tier)","minion_new"],Rotation:[0f,0f],Small:1b,Invulnerable:1b,CustomName:{text:"$(name)",color:"$(color)"},CustomNameVisible:0b,ShowArms:1b,equipment:{mainhand:{id:"$(tool)",count:1}}}
$execute unless score #minion_blocked skyblock_temp matches 1 if entity @s[y_rotation=45..135] unless entity @s[y_rotation=135..135] at @s align xz run summon minecraft:armor_stand ~0.5 ~ ~0.5 {Tags:["minion","minion_$(type)","tier_$(tier)","minion_new"],Rotation:[90f,0f],Small:1b,Invulnerable:1b,CustomName:{text:"$(name)",color:"$(color)"},CustomNameVisible:0b,ShowArms:1b,equipment:{mainhand:{id:"$(tool)",count:1}}}
$execute unless score #minion_blocked skyblock_temp matches 1 if entity @s[y_rotation=135..180] at @s align xz run summon minecraft:armor_stand ~0.5 ~ ~0.5 {Tags:["minion","minion_$(type)","tier_$(tier)","minion_new"],Rotation:[180f,0f],Small:1b,Invulnerable:1b,CustomName:{text:"$(name)",color:"$(color)"},CustomNameVisible:0b,ShowArms:1b,equipment:{mainhand:{id:"$(tool)",count:1}}}
$execute unless score #minion_blocked skyblock_temp matches 1 if entity @s[y_rotation=-180..-135] unless entity @s[y_rotation=-135..-135] at @s align xz run summon minecraft:armor_stand ~0.5 ~ ~0.5 {Tags:["minion","minion_$(type)","tier_$(tier)","minion_new"],Rotation:[180f,0f],Small:1b,Invulnerable:1b,CustomName:{text:"$(name)",color:"$(color)"},CustomNameVisible:0b,ShowArms:1b,equipment:{mainhand:{id:"$(tool)",count:1}}}
$execute unless score #minion_blocked skyblock_temp matches 1 if entity @s[y_rotation=-135..-45] unless entity @s[y_rotation=-45..-45] at @s align xz run summon minecraft:armor_stand ~0.5 ~ ~0.5 {Tags:["minion","minion_$(type)","tier_$(tier)","minion_new"],Rotation:[-90f,0f],Small:1b,Invulnerable:1b,CustomName:{text:"$(name)",color:"$(color)"},CustomNameVisible:0b,ShowArms:1b,equipment:{mainhand:{id:"$(tool)",count:1}}}
$execute unless score #minion_blocked skyblock_temp matches 1 at @s align xz run data merge entity @e[type=armor_stand,tag=minion_new,limit=1,sort=nearest] {equipment:$(armor)}
execute unless score #minion_blocked skyblock_temp matches 1 at @s align xz run tag @e[type=armor_stand,tag=minion_new,limit=1,sort=nearest] remove minion_new
$execute unless score #minion_blocked skyblock_temp matches 1 at @s align xz run summon minecraft:interaction ~0.5 ~ ~0.5 {width:0.9f,height:1.5f,Tags:["minion_interact","minion_interact_$(type)","tier_$(tier)"]}
$execute unless score #minion_blocked skyblock_temp matches 1 run title @s actionbar {"text":"$(name) placed!","color":"green"}
$execute if score #minion_blocked skyblock_temp matches 1 run give @s $(item)[minecraft:custom_name={"text":"$(name)","color":"$(color)","italic":false},minecraft:lore=[{"text":"Tier $(tier_display)","color":"gold","italic":false},{"text":"Right-click to place on the island.","color":"dark_gray","italic":false},{"text":"Left-click to pick up.","color":"dark_gray","italic":false}],minecraft:custom_data={minion_type:"$(type)",minion_tier:$(tier)b},minecraft:unbreakable={show_in_tooltip:false},minecraft:enchantment_glint_override=true,minecraft:food={nutrition:0,saturation:0.0f,can_always_eat:true},minecraft:consumable={consume_seconds:0.5f}]
execute if score #minion_blocked skyblock_temp matches 1 run title @s actionbar {"text":"Cannot place a minion on top of another minion!","color":"red"}
